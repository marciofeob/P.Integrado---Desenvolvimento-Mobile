@startuml Estoque
title STOX - Sistema de Contagem Inteligente de Estoque

actor "Operador" as Usuario
actor "SAP Business One" as SAP
actor "Google ML Kit (OCR)" as IA
actor "Impressora Térmica\n(Bluetooth ESC/POS)" as Printer

rectangle Sistema {

  Usuario --> (Realizar Login)
  Usuario --> (Configurar API SAP)
  Usuario --> (Escanear Código de Barras)
  Usuario --> (Ler Item via OCR)
  Usuario --> (Registrar Contagem Offline)
  Usuario --> (Sincronizar Inventário com SAP)
  Usuario --> (Consultar Item SAP)
  Usuario --> (Exportar Relatório CSV)
  Usuario --> (Imprimir Etiqueta)

  (Ler Item via OCR) ..> (Capturar Imagem) : <<include>>
  (Ler Item via OCR) ..> (Recortar Imagem) : <<include>>
  (Ler Item via OCR) --> IA

  (Registrar Contagem Offline) ..> (Escanear Código de Barras) : <<extend>>
  (Registrar Contagem Offline) ..> (Ler Item via OCR) : <<extend>>

  (Sincronizar Inventário com SAP) --> SAP
  (Consultar Item SAP) --> SAP
  (Imprimir Etiqueta) --> Printer

}

@enduml
